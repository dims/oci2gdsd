FROM nvidia/cuda:12.8.1-devel-ubuntu22.04 AS oci2gdsd-build

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl git build-essential pkg-config && \
    rm -rf /var/lib/apt/lists/*

ARG GO_VERSION=1.23.6
RUN curl -fsSL -o /tmp/go${GO_VERSION}.linux-amd64.tar.gz "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" && \
    tar -C /usr/local -xzf /tmp/go${GO_VERSION}.linux-amd64.tar.gz && \
    rm -f /tmp/go${GO_VERSION}.linux-amd64.tar.gz
ENV PATH="/usr/local/go/bin:${PATH}"

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=1 \
    GOOS=linux \
    GOARCH=amd64 \
    CGO_CFLAGS="-I/usr/local/cuda/include" \
    CGO_LDFLAGS="-L/usr/local/cuda/lib64 -Wl,-rpath,/usr/local/cuda/lib64" \
    go build -tags gds -trimpath -ldflags="-s -w" -o /out/oci2gdsd ./cmd/oci2gdsd

FROM nvcr.io/nvidia/ai-dynamo/vllm-runtime:0.8.1

USER root
COPY --from=oci2gdsd-build /out/oci2gdsd /usr/local/bin/oci2gdsd
COPY --from=oci2gdsd-build /usr/local/cuda/targets/x86_64-linux/lib/stubs/libcuda.so /usr/local/cuda/lib64/libcuda.so.1
RUN ln -sf /usr/local/cuda/lib64/libcufile.so.0 /usr/local/cuda/lib64/libcufile.so && \
    ln -sf /usr/local/cuda/lib64/libcufile.so /usr/lib/x86_64-linux-gnu/libcufile.so && \
    ln -sf /usr/local/cuda/lib64/libcufile.so.0 /usr/lib/x86_64-linux-gnu/libcufile.so.0
ENV LD_LIBRARY_PATH="/usr/local/cuda/lib64"
