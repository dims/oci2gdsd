# Copy or export these as needed before running k3s verify targets.
# Most users only need a few values; defaults are in platform/k3s/.env.defaults.

# Core harness
E2E_DEPLOY_MODE=daemonset-manifest
WORKLOAD_RUNTIME=pytorch
RUNTIME_PARITY_MODE=full

# TensorRT startup path knobs (used when WORKLOAD_RUNTIME=tensorrt)
TENSORRTLLM_BACKEND=pytorch
TENSORRT_STARTUP_MODE=parity
TENSORRT_ENGINE_CACHE_HOST_PATH=/mnt/nvme/oci2gdsd-tensorrt-cache
# For the PyTorch backend, point TensorRT-LLM at a locally built image from
# the torch-alias-main-single branch.
# TENSORRTLLM_RUNTIME_IMAGE=tensorrt_llm/release:torch-alias-main-single
# TENSORRTLLM_IMAGE=${TENSORRTLLM_RUNTIME_IMAGE}

# SGLang runtime image override (used when WORKLOAD_RUNTIME=sglang)
SGLANG_RUNTIME_IMAGE=lmsysorg/sglang:latest-runtime

# Perf harness knobs
K3S_PERF_MODES=cold,warm
PERF_MAX_REGRESSION_PCT=35
PERF_ENFORCE_ABSOLUTE_SLO=true

# Strict GDS policy (default is strict; keep these true for real validation)
REQUIRE_DIRECT_GDS=true
OCI2GDS_STRICT=true
OCI2GDS_PROBE_STRICT=true
OCI2GDS_FORCE_NO_COMPAT=true
ALLOW_RELAXED_GDS=false

# qwen-hello deployment validation (example app) defaults to relaxed OCI2GDS settings.
# Strict/parity enforcement is performed by daemon-client runtime jobs.
VALIDATE_QWEN_HELLO=true
QWEN_HELLO_OCI2GDS_STRICT=false
QWEN_HELLO_OCI2GDS_PROBE_STRICT=false
QWEN_HELLO_OCI2GDS_FORCE_NO_COMPAT=false
QWEN_HELLO_REQUIRE_STRICT_PROFILE_PROBE=false
QWEN_HELLO_REQUIRE_DIRECT_GDS=false
QWEN_HELLO_REQUIRE_NO_COMPAT_EVIDENCE=false
QWEN_HELLO_REQUIRE_DAEMON_IPC_PROBE=false

# Storage and model roots
OCI2GDSD_ROOT_PATH=/mnt/nvme/oci2gdsd
MIN_FREE_GB_DOCKER=100
MIN_FREE_GB_K3S=50
MIN_FREE_GB_OCI2GDS_ROOT=20

# Optional host CUDA build hints for local GDS validation
# CUDA_DEV_PACKAGE_SERIES=13-2
# CUDA_INCLUDE_DIR=/usr/local/cuda/targets/x86_64-linux/include
# CUDA_LIB_DIR=/usr/local/cuda/targets/x86_64-linux/lib

# Optional model source overrides
HF_REPO=Qwen/Qwen3-0.6B
HF_REVISION=main
MODEL_ID=qwen3-0.6b
MODEL_REPO=models/qwen3-0.6b
MODEL_TAG=v1

# Optional prebuilt model identity (skip local packaging when both are set)
# MODEL_DIGEST_OVERRIDE=sha256:...
# MODEL_REF_OVERRIDE=oci-model-registry.oci-model-registry.svc.cluster.local:5000/models/qwen3-0.6b@sha256:...

# OCI2GDSD image build knobs
OCI2GDSD_ENABLE_GDS_IMAGE=true
OCI2GDSD_DOCKERFILE=platform/k3s/Dockerfile.oci2gdsd
OCI2GDSD_DOCKER_TARGET=runtime-gds
